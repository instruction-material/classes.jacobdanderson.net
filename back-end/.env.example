MONGODB_URI=mongodb://127.0.0.1:27017/opportunity
SESSION_SECRET=replace-me
PORT=3002

# Optional Vault integration
VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=replace-me
VAULT_SECRET_ID=replace-me

# Quotes upstream transport
# Same-machine production: prefer the local Unix socket, keep the HTTPS URL as fallback.
QUOTES_UPSTREAM_SOCKET_PATH=/run/quotes/quotes.sock
QUOTES_UPSTREAM_URL=https://jacobdanderson.net/quotes-api

# Dev or non-local fallback:
# QUOTES_UPSTREAM_URL=http://127.0.0.1:4000
