# EXAMPLE .env
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OR
# openssl rand -base64 64
# If MongoDB auth is enabled, load credentials from your local secret store.
MONGODB_URI="mongodb://localhost:27017/DB_NAME_HERE"
SESSION_SECRET=
PORT=3008
PYTHON_IDE_ASSETS_ZIP_URL=https://static.classes.jacobdanderson.net/assets.zip

VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=

MDMAIL_PRIMARY_FROM=classes@example.com
MDMAIL_FALLBACK_FROM=classes@example.com
# Legacy sender overrides still read for backwards compatibility.
MDMAIL_FROM_PRIMARY=
MDMAIL_FROM_FALLBACK=
MDMAIL_FROM=
MDMAIL_ALLOW_TO=
MDMAIL_MAX_MD_LEN=200000
ADMIN_MAIL_RECIPIENTS_JSON='[{"name":"Recipient Label","emails":["primary@example.invalid","cc@example.invalid"]}]'
# Optional alternative to ADMIN_MAIL_RECIPIENTS_JSON:
# ADMIN_MAIL_RECIPIENTS_FILE=/secure/path/admin-mail-recipients.json

SMTP_PRIMARY_HOST=127.0.0.1
SMTP_PRIMARY_PORT=25
SMTP_PRIMARY_SECURE=false
SMTP_PRIMARY_SERVERNAME=mail.example.com
SMTP_PRIMARY_CA_FILE=

SMTP_FALLBACK_HOST=smtp.gmail.com
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_SECURE=false
SMTP_FALLBACK_SERVERNAME=smtp.gmail.com
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASS=
SMTP_FALLBACK_CA_FILE=

IMAP_APPEND_HOST=mail.example.com
IMAP_APPEND_PORT=993
IMAP_APPEND_SECURE=true
IMAP_APPEND_SERVERNAME=mail.example.com
IMAP_APPEND_USER=classes@example.com
IMAP_APPEND_PASS=
IMAP_SENT_MAILBOX=Sent Messages

# Legacy single-transport settings still read as the primary transport
# when SMTP_PRIMARY_* is unset.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_SERVERNAME=
SMTP_USER=
SMTP_PASS=
SMTP_CA_FILE=
