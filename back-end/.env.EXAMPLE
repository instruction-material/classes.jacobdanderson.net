# EXAMPLE .env
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OR
# openssl rand -base64 64
#MONGODB_URI="mongodb://appuser:secretpassword@localhost:27017/DB_NAME_HERE?authSource=admin"
MONGODB_URI="mongodb://localhost:27017/DB_NAME_HERE"
SESSION_SECRET="SECRET_VALUE_HERE" # Like af8fb3d9d324792a867420f985cdf1b16e91dd086d5852e355c3922e05858a51
PORT=3008

VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=NOT_NEEDED_HERE_TESTING_TESTING_0
VAULT_SECRET_ID=NOT_NEEDED_HERE_TESTING_TESTING_1

MDMAIL_PRIMARY_FROM=classes@jacobdanderson.net
MDMAIL_FALLBACK_FROM=jacobdanderson@gmail.com
# Legacy sender overrides still read for backwards compatibility.
MDMAIL_FROM_PRIMARY=
MDMAIL_FROM_FALLBACK=
MDMAIL_FROM=
MDMAIL_ALLOW_TO=
MDMAIL_MAX_MD_LEN=200000

SMTP_PRIMARY_HOST=127.0.0.1
SMTP_PRIMARY_PORT=25
SMTP_PRIMARY_SECURE=false
SMTP_PRIMARY_SERVERNAME=mail.stridewithus.co
SMTP_PRIMARY_CA_FILE=

SMTP_FALLBACK_HOST=smtp.gmail.com
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_SECURE=false
SMTP_FALLBACK_SERVERNAME=smtp.gmail.com
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASS=
SMTP_FALLBACK_CA_FILE=

# Legacy single-transport settings still read as the primary transport
# when SMTP_PRIMARY_* is unset.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_SERVERNAME=
SMTP_USER=
SMTP_PASS=
SMTP_CA_FILE=
