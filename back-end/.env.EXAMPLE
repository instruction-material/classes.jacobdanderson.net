# openssl rand -base64 64
#MONGODB_URI="mongodb://appuser:secretpassword@localhost:27017/DB_NAME_HERE?authSource=admin"
MONGODB_URI="mongodb://localhost:27017/DB_NAME_HERE"
SESSION_SECRET="SECRET_VALUE_HERE" # Like af8fb3d9d324792a867420f985cdf1b16e91dd086d5852e355c3922e05858a51
PORT=3008

VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=NOT_NEEDED_HERE_TESTING_TESTING_0
VAULT_SECRET_ID=NOT_NEEDED_HERE_TESTING_TESTING_1

MDMAIL_FROM_PRIMARY=classes@jacobdanderson.net
MDMAIL_FROM_FALLBACK=jacobdanderson@gmail.com
# Legacy override: treated as the primary sender when MDMAIL_FROM_PRIMARY is unset.
MDMAIL_FROM=
MDMAIL_ALLOW_TO=
MDMAIL_MAX_MD_LEN=200000

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_SERVERNAME=mail.stridewithus.co
SMTP_USER=
SMTP_PASS=
SMTP_CA_FILE=
