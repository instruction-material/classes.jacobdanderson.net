{
	"name": "front-end",
	"version": "2.0.0",
	"description": "",
	"author": "Instruction Material contributors",
	"keywords": [],
	"license": "ISC",
	"type": "module",
	"engines": {
		"node": ">=22 <23"
	},
	"private": true,
	"main": "dist/script.js",
	"scripts": {
		"build": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage vite-ssg build",
		"dev": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage vite --port 3333 --open",
		"start": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage vite --port 3333 --open --host",
		"serve": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage vite --port 3333 --open --host",
		"preview": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage vite preview",
		"preview-https": "serve dist",
		"test": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage vitest run",
		"test:e2e": "cypress open",
		"test:unit": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage vitest run",
		"typecheck": "vue-tsc --noEmit",
		"up": "npm exec --yes -- taze major -I",
		"postinstall": "npx simple-git-hooks",
		"lint": "eslint \"src/**/*.{js,ts,vue}\"",
		"lint-fix": "eslint \"src/**/*.{js,ts,vue}\" --fix"
	},
	"dependencies": {
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/vue-fontawesome": "^3.1.3",
		"@unhead/vue": "^3.0.2",
		"@unocss/reset": "^66.6.8",
		"@vueuse/core": "^14.2.1",
		"axios": "^1.15.0",
		"bootstrap": "^5.3.8",
		"dompurify": "^3.3.3",
		"leaflet": "^1.9.4",
		"markdown-it": "^14.1.1",
		"nprogress": "^0.2.0",
		"pinia": "^3.0.4",
		"unhead": "^3.0.2",
		"vite-plugin-pages": "^0.33.3",
		"vite-plugin-vue-layouts-next": "^2.1.0",
		"vue": "^3.5.32",
		"vue-demi": "^0.14.10",
		"vue-i18n": "^11.3.2",
		"vue-router": "^5.0.4",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@iconify-json/carbon": "^1.2.20",
		"@iconify/utils": "^3.1.0",
		"@volar/typescript": "^2.4.28",
		"@types/bootstrap": "^5.2.10",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.6.0",
		"@types/nprogress": "^0.2.3",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vue/test-utils": "^2.4.6",
		"alien-signals": "^3.1.2",
		"beasties": "^0.3.5",
		"consola": "^3.4.2",
		"cross-env": "^10.1.0",
		"cypress": "^15.13.1",
		"eslint-plugin-format": "^2.0.1",
		"gzip-size": "^6.0.0",
		"lint-staged": "^16.4.0",
		"rolldown": "^1.0.0-rc.15",
		"rollup": "^4.52.4",
		"simple-git-hooks": "^2.13.1",
		"unocss": "^66.6.8",
		"unplugin-auto-import": "^21.0.0",
		"unplugin-vue-components": "^31.1.0",
		"vite": "^8.0.8",
		"vite-ssg": "^28.3.0",
		"vite-ssg-sitemap": "^0.10.0",
		"vitest": "^4.1.4",
		"vue-eslint-parser": "^10.4.0",
		"vue-tsc": "^3.2.6"
	},
	"resolutions": {
		"unplugin": "^3.0.0",
		"vite": "^8.0.8",
		"vue-router": "^5.0.4"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*.{ts,js,vue}": [
			"eslint --fix"
		]
	},
	"browserslist": [
		"> 1%",
		"last 2 versions",
		"not dead",
		"not ie 11"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/instruction-material/classes.jacobdanderson.net"
	},
