{
	"name": "classes-monorepo",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"packageManager": "npm@11.12.0",
	"description": "Monorepo for Classes project",
	"author": "Jacob Anderson",
	"license": "ISC",
	"keywords": [],
	"workspaces": [
		"front-end",
		"back-end"
	],
	"scripts": {
		"audit": "npm audit --workspaces",
		"audit-fix": "npm audit fix --workspaces",
		"build": "npm run -w front-end build && npm run -w back-end build",
		"dev": "npm run -w front-end dev",
		"server": "npm run -w back-end server",
		"server:once": "npm run -w back-end server:once",
		"serve": "npm run -w front-end serve",
		"a11y": "node scripts/a11y-smoke.mjs",
		"lint-server": "npm run -w back-end lint-fix && npm run -w back-end server",
		"lint-serve": "npm run -w front-end lint-fix && npm run -w front-end serve",
		"lint": "npm run -w front-end lint && npm run -w back-end lint",
		"lint-fix": "npm run -w front-end lint-fix && npm run -w back-end lint-fix",
		"typecheck": "npm run -w front-end typecheck && npm run -w back-end typecheck",
		"clean": "sudo rm -rf node_modules dist package-lock.json **/node_modules **/dist **/package-lock.json",
		"up": "npm exec --yes -- taze major -I && npm run -w front-end up && npm run -w back-end up"
	},
	"overrides": {
		"defu": "6.1.6",
		"eslint-plugin-import": {
			"minimatch": "^3.1.5"
		},
		"@vue/language-core": {
			"minimatch": "^9.0.9"
		},
		"path-to-regexp": "8.4.0",
		"serialize-javascript": "7.0.5",
		"picomatch": "4.0.4",
		"anymatch": {
			"picomatch": "2.3.2"
		},
		"micromatch": {
			"picomatch": "2.3.2"
		},
		"readdirp": {
			"picomatch": "2.3.2"
		},
		"@rollup/plugin-babel": {
			"@rollup/pluginutils": {
				"picomatch": "2.3.2"
			}
		},
		"@rollup/plugin-replace": {
			"@rollup/pluginutils": {
				"picomatch": "2.3.2"
			}
		},
		"vue-i18n": "^11.3.0",
		"vite": "^8.0.8",
		"vue-router": "^5.0.4",
		"follow-redirects": "1.16.0",
		"@cypress/request": {
			"uuid": "14.0.0",
			"qs": "6.15.2"
		}
	},
	"allowScripts": {
		"argon2@0.44.0": true,
		"cypress@15.16.0": true,
		"esbuild@0.28.1": true,
		"fsevents@2.3.3": true,
		"puppeteer@24.43.1": true,
		"simple-git-hooks@2.13.1": true,
		"vue-demi@0.14.10": true
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.2.0",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"@unocss/eslint-plugin": "^66.6.7",
		"axe-core": "^4.11.4",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-vue": "^10.8.0",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"puppeteer": "^24.43.1",
		"taze": "^19.11.0",
		"typescript": "^6.0.3"
	}
}
